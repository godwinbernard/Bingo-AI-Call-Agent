{
  "name": "voice-ai-agent",
  "version": "1.0.0",
  "description": "Voice AI Agent with Twilio, Deepgram, ElevenLabs, and Claude",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "setup:stripe": "node scripts/setupStripe.js",
    "cron:daily": "node scripts/cron/daily.js",
    "cron:monthly": "node scripts/cron/monthly.js",
    "cron:hourly": "node scripts/cron/hourly.js",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "test:e2e": "jest tests/e2e --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:dryrun": "jest tests/e2e/dryRun.test.js --verbose --runInBand"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@clerk/backend": "^1.10.0",
    "@deepgram/sdk": "^3.0.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "phone": "^3.1.0",
    "prisma": "^5.20.0",
    "@prisma/client": "^5.20.0",
    "resend": "^4.0.0",
    "slugify": "^1.6.6",
    "stripe": "^16.12.0",
    "zod": "^3.23.8",
    "twilio": "^5.1.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
