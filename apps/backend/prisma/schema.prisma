generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  STARTER
  GROWTH
  ENTERPRISE
  PAY_AS_YOU_GO
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  VIEWER
}

enum MemberStatus {
  active
  invited
  suspended
}

enum InvitationStatus {
  pending
  accepted
  expired
}

enum InvoiceStatus {
  paid
  open
  void
  uncollectible
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum HumanCallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
  CANCELED
}

enum HumanCallOutcome {
  SUCCESS
  CALLBACK_REQUESTED
  NOT_INTERESTED
  VOICEMAIL_LEFT
  WRONG_NUMBER
  DO_NOT_CALL
  NO_ANSWER
  FAILED
}

enum Speaker {
  AGENT
  CONTACT
  UNKNOWN
}

enum HintType {
  OBJECTION_RESPONSE
  RAPPORT_TIP
  CLOSING_SUGGESTION
  SPEED_WARNING
  SCRIPT_REMINDER
  SENTIMENT_ALERT
  KEYWORD_DETECTED
}

enum SessionStatus {
  ACTIVE
  PAUSED
  ENDED
}

model Organization {
  id                    String             @id @default(cuid())
  name                  String
  slug                  String             @unique
  logo_url              String?
  stripe_customer_id    String             @unique
  stripe_subscription_id String?
  subscription_tier     SubscriptionTier
  subscription_status   SubscriptionStatus
  trial_ends_at         DateTime?
  billing_email         String
  billing_name          String?
  calls_used_this_month Int                @default(0)
  usage_reset_date      DateTime
  timezone              String             @default("America/New_York")
  call_hours_start      String             @default("08:00")
  call_hours_end        String             @default("21:00")
  max_concurrent        Int                @default(1)
  members               OrganizationMember[]
  campaigns             Campaign[]
  scripts               Script[]
  contacts              Contact[]
  calls                 Call[]
  invoices              Invoice[]
  api_keys              ApiKey[]
  audit_logs            AuditLog[]
  usage_records         UsageRecord[]
  invitations           Invitation[]
  subscriptions         Subscription[]
  dnc_lists             DncList[]
  human_calls           HumanCall[]
  call_scorecards       CallScorecard[]
  agent_performances    AgentPerformance[]
  dialer_sessions       DialerSession[]
  stripe_webhook_events StripeWebhookEvent[]
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
}

model OrganizationMember {
  id              String         @id @default(cuid())
  organization_id String
  user_id         String
  email           String
  name            String
  role            MemberRole
  invited_by      String?
  invited_at      DateTime?
  joined_at       DateTime?
  status          MemberStatus   @default(active)
  organization    Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime       @default(now())
  human_calls_as_agent HumanCall[]
  call_scorecards     CallScorecard[]
  agent_performances  AgentPerformance[]
  dialer_sessions     DialerSession[]

  @@index([organization_id])
  @@index([user_id])
  @@unique([organization_id, user_id])
}

model Invitation {
  id              String           @id @default(cuid())
  organization_id String
  email           String
  role            MemberRole
  token           String           @unique
  invited_by      String
  expires_at      DateTime
  accepted_at     DateTime?
  revoked_at      DateTime?
  revoked_by      String?
  status          InvitationStatus @default(pending)
  organization    Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime         @default(now())

  @@index([organization_id])
  @@index([email])
}

model Subscription {
  id                      String             @id @default(cuid())
  organization_id         String             @unique
  stripe_subscription_id  String             @unique
  stripe_price_id         String
  tier                    SubscriptionTier
  status                  SubscriptionStatus
  current_period_start    DateTime
  current_period_end      DateTime
  cancel_at_period_end    Boolean            @default(false)
  canceled_at             DateTime?
  trial_start             DateTime?
  trial_end               DateTime?
  organization            Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt
}

model Invoice {
  id              String        @id @default(cuid())
  organization_id String
  stripe_invoice_id String      @unique
  amount_paid     Int
  amount_due      Int
  currency        String
  status          InvoiceStatus
  invoice_url     String?
  invoice_pdf     String?
  period_start    DateTime
  period_end      DateTime
  paid_at         DateTime?
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime      @default(now())

  @@index([organization_id])
}

model UsageRecord {
  id              String        @id @default(cuid())
  organization_id String
  month           String
  calls_made      Int           @default(0)
  minutes_used    Int           @default(0)
  amount_cents    Int           @default(0)
  recorded_at     DateTime      @default(now())
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, month])
}

model ApiKey {
  id              String        @id @default(cuid())
  organization_id String
  name            String
  key_hash        String
  key_prefix      String
  last_used_at    DateTime?
  expires_at      DateTime?
  is_active       Boolean       @default(true)
  created_by      String
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime      @default(now())

  @@index([organization_id])
}

model AuditLog {
  id              String        @id @default(cuid())
  organization_id String
  user_id         String?
  action          String
  resource_type   String
  resource_id     String?
  metadata        Json?
  ip_address      String?
  user_agent      String?
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime      @default(now())

  @@index([organization_id, created_at])
}

model Campaign {
  id              String       @id @default(cuid())
  organization_id String
  name            String
  status          String       @default("draft")
  metadata        Json?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  human_calls     HumanCall[]
  dialer_sessions DialerSession[]
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  @@index([organization_id])
}

model Script {
  id              String       @id @default(cuid())
  organization_id String
  name            String
  content         Json
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  @@index([organization_id])
}

model Contact {
  id              String       @id @default(cuid())
  organization_id String
  name            String
  phone           String
  email           String?
  metadata        Json?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  human_calls     HumanCall[]
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  @@index([organization_id])
}

model Call {
  id              String       @id @default(cuid())
  organization_id String
  call_sid        String       @unique
  campaign_id     String?
  status          String
  duration_seconds Int          @default(0)
  outcome         String?
  transcript      Json?
  error_message   String?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  @@index([organization_id])
  @@index([campaign_id])
}

model DncList {
  id              String       @id @default(cuid())
  organization_id String
  phone           String
  reason          String?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime     @default(now())

  @@index([organization_id])
}

model HumanCall {
  id                 String             @id @default(cuid())
  org_id             String
  agent_id           String
  contact_id         String
  campaign_id        String?
  twilio_call_sid    String             @unique
  twilio_parent_sid  String?
  direction          CallDirection
  recording_url      String?
  recording_sid      String?
  recording_duration Int?
  status             HumanCallStatus
  outcome            HumanCallOutcome?
  outcome_notes      String?
  started_at         DateTime?
  answered_at        DateTime?
  ended_at           DateTime?
  duration_seconds   Int?
  talk_time_agent    Int?
  talk_time_contact  Int?
  hold_time          Int?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt

  organization       Organization       @relation(fields: [org_id], references: [id])
  agent              OrganizationMember @relation(fields: [agent_id], references: [id])
  contact            Contact            @relation(fields: [contact_id], references: [id])
  campaign           Campaign?          @relation(fields: [campaign_id], references: [id])
  transcript         CallTranscript?
  scorecard          CallScorecard?
  segments           TranscriptSegment[]
  hints              AiHint[]

  @@index([org_id])
  @@index([agent_id])
  @@index([contact_id])
  @@index([campaign_id])
}

model CallTranscript {
  id                  String            @id @default(cuid())
  call_id             String            @unique
  full_text           String
  word_count          Int
  talk_ratio_agent    Float
  talk_ratio_contact  Float
  filler_word_count   Int
  avg_confidence      Float
  avg_sentiment       Float
  keywords_detected   String[]
  objections_detected String[]
  created_at          DateTime          @default(now())

  call                HumanCall         @relation(fields: [call_id], references: [id], onDelete: Cascade)
  segments            TranscriptSegment[]
}

model TranscriptSegment {
  id              String           @id @default(cuid())
  call_id         String
  transcript_id   String?
  speaker         Speaker
  text            String
  start_ms        Int
  end_ms          Int
  confidence      Float
  sentiment_score Float
  words_per_min   Int?
  is_objection    Boolean          @default(false)
  objection_type  String?
  created_at      DateTime         @default(now())

  call            HumanCall        @relation(fields: [call_id], references: [id], onDelete: Cascade)
  transcript      CallTranscript?  @relation(fields: [transcript_id], references: [id], onDelete: SetNull)

  @@index([call_id])
  @@index([transcript_id])
}

model CallScorecard {
  id                       String             @id @default(cuid())
  call_id                  String             @unique
  agent_id                 String
  org_id                   String
  overall_score            Float
  opening_score            Float
  objection_handling_score Float
  rapport_score            Float
  script_adherence_score   Float
  closing_score            Float
  what_went_well           String[]
  what_to_improve          String[]
  coaching_tips            String[]
  summary                  String
  sentiment_timeline       Json
  talk_speed_avg           Int
  filler_word_count        Int
  longest_monologue_sec    Int
  interruptions_count      Int
  ai_model_used            String
  analysis_duration_ms     Int
  created_at               DateTime           @default(now())

  call                     HumanCall          @relation(fields: [call_id], references: [id], onDelete: Cascade)
  agent                    OrganizationMember @relation(fields: [agent_id], references: [id])
  organization             Organization       @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@index([org_id])
  @@index([agent_id])
}

model AiHint {
  id              String      @id @default(cuid())
  call_id         String
  triggered_at_ms  Int
  hint_type       HintType
  content         String
  objection_type  String?
  was_used        Boolean     @default(false)
  dismissed       Boolean     @default(false)
  created_at      DateTime    @default(now())

  call            HumanCall   @relation(fields: [call_id], references: [id], onDelete: Cascade)

  @@index([call_id])
}

model AgentPerformance {
  id                String             @id @default(cuid())
  agent_id          String
  org_id            String
  period            String
  calls_made        Int                @default(0)
  calls_connected   Int                @default(0)
  calls_successful  Int                @default(0)
  total_talk_time   Int                @default(0)
  avg_overall_score Float?
  avg_opening       Float?
  avg_objection     Float?
  avg_rapport       Float?
  avg_closing       Float?
  top_issues        String[]
  improvement_areas String[]
  score_trend       Float[]
  updated_at        DateTime           @updatedAt
  created_at        DateTime           @default(now())

  agent             OrganizationMember @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  organization      Organization       @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@unique([agent_id, period])
  @@index([org_id, period])
}

model DialerSession {
  id            String             @id @default(cuid())
  agent_id      String
  org_id        String
  campaign_id   String?
  twilio_device String?
  status        SessionStatus
  calls_made    Int                @default(0)
  started_at    DateTime           @default(now())
  ended_at      DateTime?

  agent         OrganizationMember @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  organization  Organization       @relation(fields: [org_id], references: [id], onDelete: Cascade)
  campaign      Campaign?          @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  @@index([org_id])
  @@index([agent_id])
  @@index([campaign_id])
}

model StripeWebhookEvent {
  id               String       @id @default(cuid())
  organization_id  String
  stripe_event_id  String       @unique
  event_type       String
  payload          Json
  status           String       @default("pending")
  attempt_count    Int          @default(0)
  next_retry_at    DateTime?
  last_error       String?
  processed_at     DateTime?
  organization     Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@index([organization_id, status, next_retry_at])
}
