NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# WebSocket backend for live transcript (same as API base URL in most setups)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
ADMIN_SECRET=your_secret_here

# Human Dialer
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_API_KEY_SID=SK...
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret
TWILIO_TWIML_APP_SID=AP...
TWILIO_CALLER_ID=+1...
TWILIO_HOLD_MUSIC_URL=https://yourcdn.example.com/hold-music.mp3
DEEPGRAM_API_KEY=dg_...
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_RECORDINGS_BUCKET=bingo-ai-recordings-dev
SOCKET_IO_SECRET=your_socket_secret
